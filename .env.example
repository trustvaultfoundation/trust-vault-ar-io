# trust-vault-ar-io — deploy config (copy to .env.local and fill in for `npm run deploy`).
# Only needed to publish to Arweave / the `trustvault` ArNS name. The site itself ships no secrets.

# Wallet that owns the `trustvault` ArNS name and pays for the upload.
# Accepts an Arweave JWK (JSON or base64), an EVM private key, or a Solana key.
# SECRET — never commit the real value.
DEPLOY_WALLET_JWK=

# Optional: force the signer type when it can't be inferred (arweave | ethereum | polygon | solana).
DEPLOY_SIG_TYPE=
